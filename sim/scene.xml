<!--
  Сцена ПАК сортировки (Трек 3).

  Мировая СК: X — направление подачи (точка A -> накопитель), Y — влево
  (в сторону зоны B), Z — вверх. Начало координат — центр накопителя.

  Планировка по схеме участка (мм -> м):
  - рабочая зона 6000x10000: x in [-8.6, 1.4], y in [-3, 3];
  - подающий конвейер A: лента 500 мм, верх на 700 мм, скорость 1 м/с,
    от x=-7.6 до накопителя (точка A на 1000 мм от края зоны);
  - накопитель: стол 1.2x1.2 м с низким трением (роликовый стол) и упором;
  - зона B (основной сортировщик): лента 500 мм на y=+1.5 м от оси подачи
    (фиксировано схемой), подача через гравитационный лоток;
  - зоны C и D: ролл-кейджи 1200x800x800, размещение свободное — поставлены
    в зоне досягаемости манипулятора.

  Ленты реализованы физически: тело ленты на слайд-шарнире с velocity-
  актуатором; периодический "wrap" положения делает ленту бесконечной
  (см. robozone/sim_core.py). Товары едут за счёт трения.

-->
<mujoco model="robozone_pak">
  <compiler angle="radian" meshdir="../assets" autolimits="true"/>
  <option timestep="0.002" integrator="implicitfast" cone="elliptic" impratio="10"/>

  <visual>
    <headlight diffuse="0.5 0.5 0.5" ambient="0.4 0.4 0.45" specular="0.3 0.3 0.3"/>
    <quality shadowsize="4096"/>
    <map znear="0.05"/>
    <global offwidth="1280" offheight="720"/>
  </visual>

  <statistic center="-0.5 0 0.9" extent="3.5"/>

  <default>
    <default class="static_gray">
      <geom type="box" rgba="0.62 0.62 0.64 1" friction="0.4 0.005 0.0001"/>
    </default>
    <default class="rail">
      <geom type="box" rgba="0.3 0.45 0.75 1" friction="0.2 0.005 0.0001"/>
    </default>
    <default class="belt_surf">
      <geom type="box" rgba="0.18 0.18 0.2 1" friction="1.1 0.01 0.001"/>
    </default>
    <default class="slide_low_fric">
      <geom type="box" rgba="0.75 0.75 0.78 1" friction="0.1 0.005 0.0001"/>
    </default>
    <default class="cage">
      <geom type="box" rgba="0.25 0.45 0.9 0.5" friction="0.6 0.005 0.0001"/>
    </default>
    <default class="object">
      <geom type="mesh" condim="6" friction="0.9 0.02 0.002" solref="0.01 1" group="1"/>
    </default>
    <default class="marker">
      <site type="sphere" size="0.035" group="5"/>
    </default>
  </default>

  <include file="cell_ur10e.xml"/>
  <include file="objects.xml"/>

  <worldbody>
    <light name="top_light" dir="0 0 -1" pos="-2 0 6" diffuse="0.7 0.7 0.7" directional="true"/>
    <light name="cell_light" dir="-0.3 0 -1" pos="1.5 0 4" diffuse="0.5 0.5 0.5"/>

    <geom name="floor" type="plane" size="14 6 0.1" pos="-2 0 0"
          rgba="0.82 0.83 0.85 1" friction="0.8 0.005 0.0001"/>

    <!-- Граница рабочей зоны 6000x10000 (визуализация) -->
    <geom name="wz_south" type="box" size="5.0 0.01 0.001" pos="-3.6 -3 0.002"
          rgba="0.9 0.1 0.1 1" contype="0" conaffinity="0"/>
    <geom name="wz_north" type="box" size="5.0 0.01 0.001" pos="-3.6 3 0.002"
          rgba="0.9 0.1 0.1 1" contype="0" conaffinity="0"/>
    <geom name="wz_west" type="box" size="0.01 3.0 0.001" pos="-8.6 0 0.002"
          rgba="0.9 0.1 0.1 1" contype="0" conaffinity="0"/>
    <geom name="wz_east" type="box" size="0.01 3.0 0.001" pos="1.4 0 0.002"
          rgba="0.9 0.1 0.1 1" contype="0" conaffinity="0"/>

    <!-- ================= Подающий конвейер (точка A) ================= -->
    <body name="conveyor_a_frame" pos="-4.17 0 0">
      <geom class="static_gray" size="3.53 0.27 0.32" pos="0 0 0.32"/>
    </body>
    <!-- Движущаяся лента: слайд по X, wrap в коде -->
    <body name="belt_a" pos="-4.165 0 0.68">
      <joint name="belt_a_joint" type="slide" axis="1 0 0" damping="5"/>
      <geom name="belt_a_surf" class="belt_surf" size="3.54 0.25 0.02" mass="60"/>
    </body>
    <!-- Борта ленты (зазор 5 мм над лентой) -->
    <geom class="rail" name="rail_a_left" size="3.42 0.015 0.06" pos="-4.28 0.28 0.765"/>
    <geom class="rail" name="rail_a_right" size="3.42 0.015 0.06" pos="-4.28 -0.28 0.765"/>
    <site name="point_A" class="marker" pos="-7.6 0 0.75" rgba="0.2 0.9 0.2 0.7"/>

    <!-- Расширение к накопителю (направляющие) -->
    <geom class="rail" name="funnel_left" size="0.21 0.015 0.07" pos="-0.675 0.42 0.775"
          euler="0 0 0.906"/>
    <geom class="rail" name="funnel_right" size="0.21 0.015 0.07" pos="-0.675 -0.42 0.775"
          euler="0 0 -0.906"/>

    <!-- ================= Накопитель ================= -->
    <!-- Борта низкие (75 мм): удерживают товар, не мешая манипулятору -->
    <body name="accumulator" pos="0 0 0">
      <!-- Поверхность накопителя удерживает товар для захвата (не роликовая) -->
      <geom type="box" name="acc_table" size="0.6 0.6 0.02" pos="0 0 0.66"
            rgba="0.7 0.72 0.75 1" friction="0.9 0.01 0.001"/>
      <geom class="rail" name="acc_wall_end" size="0.015 0.6 0.0375" pos="0.615 0 0.7175"/>
      <geom class="rail" name="acc_wall_left" size="0.6 0.015 0.0375" pos="0 0.615 0.7175"/>
      <geom class="rail" name="acc_wall_right" size="0.6 0.015 0.0375" pos="0 -0.615 0.7175"/>
    </body>
    <site name="pick_zone" class="marker" pos="0.15 0 0.75" rgba="0.9 0.9 0.2 0.7"/>

    <!-- ================= Зона B: основной сортировщик ================= -->
    <!-- Питающая (диверторная) лента от зоны досягаемости манипулятора к инфиду
         сортера. Товар кладётся на ближний конец (в пределах вылета руки),
         лента переносит его к точке B. Инфид сортера — фиксированный элемент. -->
    <body name="conveyor_b_frame" pos="0.75 2.05 0">
      <geom class="static_gray" size="0.27 1.05 0.32" pos="0 0 0.32"/>
    </body>
    <body name="belt_b" pos="0.75 2.04 0.68">
      <joint name="belt_b_joint" type="slide" axis="0 1 0" damping="5"/>
      <geom name="belt_b_surf" class="belt_surf" size="0.25 1.06 0.02" mass="30"/>
    </body>
    <geom class="rail" name="rail_b_left" size="0.015 1.05 0.05" pos="0.48 2.05 0.755"/>
    <geom class="rail" name="rail_b_right" size="0.015 1.05 0.05" pos="1.02 2.05 0.755"/>
    <!-- Инфид сортера (за границей задачи, визуальный "приёмник") -->
    <geom class="static_gray" name="sorter_infeed" type="box" size="0.3 0.08 0.55"
          pos="0.75 3.25 0.55" rgba="0.45 0.45 0.5 1"/>
    <site name="point_B" class="marker" pos="0.75 3.0 0.8" rgba="0.2 0.9 0.2 0.7"/>

    <!-- ================= Зоны C и D: ролл-кейджи 1200x800x800 ============ -->
    <!-- Размещение свободное в пределах рабочей зоны. Кейджи центрированы под
         достижимыми точками сброса манипулятора (ближний край — у точки сброса),
         борта умеренной высоты для чистого сброса сверху. -->
    <!-- C: негабарит (кейдж 800×1240 мм, центр под точкой сброса) -->
    <body name="cage_c" pos="0.25 -1.05 0">
      <geom class="cage" name="cage_c_floor" size="0.40 0.62 0.025" pos="0 0 0.075"
            rgba="0.2 0.38 0.8 1"/>
      <geom class="cage" name="cage_c_w1" size="0.40 0.02 0.26" pos="0 0.60 0.36"/>
      <geom class="cage" name="cage_c_w2" size="0.40 0.02 0.26" pos="0 -0.60 0.36"/>
      <geom class="cage" name="cage_c_w3" size="0.02 0.62 0.26" pos="-0.38 0 0.36"/>
      <geom class="cage" name="cage_c_w4" size="0.02 0.62 0.26" pos="0.38 0 0.36"/>
    </body>
    <site name="point_C" class="marker" pos="0.25 -0.7 1.05" rgba="0.9 0.5 0.1 0.7"/>

    <!-- D: доупаковка -->
    <body name="cage_d" pos="1.05 -1.05 0">
      <geom class="cage" name="cage_d_floor" size="0.40 0.62 0.025" pos="0 0 0.075"
            rgba="0.2 0.38 0.8 1"/>
      <geom class="cage" name="cage_d_w1" size="0.40 0.02 0.26" pos="0 0.60 0.36"/>
      <geom class="cage" name="cage_d_w2" size="0.40 0.02 0.26" pos="0 -0.60 0.36"/>
      <geom class="cage" name="cage_d_w3" size="0.02 0.62 0.26" pos="-0.38 0 0.36"/>
      <geom class="cage" name="cage_d_w4" size="0.02 0.62 0.26" pos="0.38 0 0.36"/>
    </body>
    <site name="point_D" class="marker" pos="1.05 -0.7 1.05" rgba="0.9 0.5 0.1 0.7"/>

    <!-- Стеллаж парковки объектов (за пределами рабочей зоны) -->
    <geom class="static_gray" name="park_shelf" size="0.8 3.0 0.15" pos="-11 0 0.15"
          rgba="0.5 0.5 0.5 1"/>

    <!-- ================= Камеры ================= -->
    <!-- Обзор ленты для CV-части -->
    <camera name="cam_overhead" pos="-3.5 0 3.0" quat="1 0 0 0" fovy="50"/>
    <!-- Камера над накопителем (зона захвата) -->
    <camera name="cam_pick" pos="0 0 2.6" quat="1 0 0 0" fovy="55"/>
    <!-- Общий вид ячейки -->
    <camera name="cam_global" pos="-2.5 -4.5 3.6" zaxis="-0.35 -0.75 0.55" fovy="55"/>
  </worldbody>

  <actuator>
    <velocity name="belt_a_drive" joint="belt_a_joint" kv="2000" ctrlrange="-2 2"/>
    <velocity name="belt_b_drive" joint="belt_b_joint" kv="1000" ctrlrange="-2 2"/>
  </actuator>
</mujoco>
